# Resend API key for sending contact form notification emails
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx

# Email address that receives contact form notifications
CONTACT_EMAIL=hello@synctexts.com

# Custom sender address (requires verified domain in Resend)
# Defaults to 'SyncTexts <onboarding@resend.dev>' for testing
EMAIL_FROM=

# Admin credentials for the submissions dashboard (Phase 3, Plan 2)
ADMIN_USER=admin
ADMIN_PASS=changeme

# Google Tag Manager container ID (public, exposed to client)
# Get yours at: https://tagmanager.google.com → Container → Admin → Container ID
PUBLIC_GTM_ID=GTM-XXXXXXX

# GA4 Measurement ID (configured inside GTM, not used in code directly)
# Included here for reference only -- set up as a GA4 tag in GTM
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
