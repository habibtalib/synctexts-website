# Resend API key for sending contact form notification emails
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx

# Email address that receives contact form notifications
CONTACT_EMAIL=hello@synctexts.com

# Custom sender address (requires verified domain in Resend)
# Defaults to 'SyncTexts <onboarding@resend.dev>' for testing
EMAIL_FROM=

# Admin credentials for the submissions dashboard (Phase 3, Plan 2)
ADMIN_USER=admin
ADMIN_PASS=changeme
