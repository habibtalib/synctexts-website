---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import BackgroundGlows from '../components/BackgroundGlows.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import JsonLdOrganization from '../components/SEO/JsonLdOrganization.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  canonicalUrl?: string;
  jsonLd?: object;
}

const {
  title,
  description = 'SyncTexts is a leading tech agency specializing in Web Development, DevOps, and Data Analytics.',
  image = '/og-default.png',
  type = 'website',
  canonicalUrl,
} = Astro.props;

const fullTitle = `${title} | SyncTexts`;
const canonical = canonicalUrl || new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="SyncTexts" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <JsonLdOrganization />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <BackgroundGlows />
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/animations.js';
    </script>
  </body>
</html>
