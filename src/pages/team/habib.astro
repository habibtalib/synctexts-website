---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Professional experience — sourced from Habib's profile.
// Companies with multiple roles use the `roles` array; single-role
// entries use `role`/`period`/`description`.
const experience = [
  {
    company: 'Battut',
    meta: 'Full-time · Remote · Kuala Lumpur, Malaysia',
    roles: [
      {
        title: 'Chief Executive Officer',
        period: 'May 2026 — Present',
        points: [
          'Leading a Syariah-compliant social media platform scaling across the MENA region.',
          'Driving product, content, and user growth strategy.',
        ],
        tags: ['Firebase', 'Cloud Firestore', 'Product Strategy'],
      },
    ],
  },
  {
    company: 'SyncTexts',
    meta: 'Self-employed · Hybrid · Kuala Lumpur, Malaysia',
    roles: [
      {
        title: 'Chief Executive Officer',
        period: 'Dec 2021 — Present · 4+ yrs',
        points: [
          'Founded and lead a software house delivering web platforms for government and enterprise clients — plus training and Agile coaching.',
          'Shipped 15+ production systems including Sistem Pinjaman Negeri Sembilan, Guru Kafa (JAIS), Yayasan Pelajaran Johor, Smart Docket Selangor, FIMM, and The Merdeka Times.',
          'Delivered hands-on training: Laravel with Claude Code (SUK Kedah), Introduction to Figma (JPJ), and AI Video Generation with Veo 3 (Persatuan OKU Malaysia).',
        ],
        tags: ['Laravel', 'Agile Coaching', 'FilamentPHP', 'Training'],
      },
    ],
  },
  {
    company: 'Tarbyh',
    meta: 'Full-time · Remote · Cyberjaya, Malaysia',
    roles: [
      {
        title: 'Founder',
        period: 'Aug 2025 — Present',
        points: ['Building an early-stage startup with a focus on growth and product-market fit.'],
        tags: ['Startups', 'Growth Hacking'],
      },
    ],
  },
  {
    company: 'HASAN.VC',
    meta: 'Full-time · Remote · Kuala Lumpur, Malaysia',
    roles: [
      {
        title: 'Fellow — Cohort 003',
        period: 'Aug 2025 — Present',
        points: ['Selected fellow exploring venture capital and the startup ecosystem.'],
        tags: ['Venture Capital', 'Startups'],
      },
    ],
  },
  {
    company: 'PINC Technology Sdn Bhd',
    meta: 'Hybrid · Shah Alam, Malaysia · 1 yr 7 mos',
    roles: [
      {
        title: 'Technology Consultant',
        period: 'Aug 2025 — Present · Contract',
        points: ['TechOps implementations, cloud architecture, and DevOps operations setup.'],
        tags: ['AWS', 'Cloud Architecture', 'DevOps', 'Jira Service Desk'],
      },
      {
        title: 'Software Architect',
        period: 'Dec 2024 — Jul 2025 · Part-time',
        points: ['Defined software and platform architecture for client systems.'],
        tags: ['Software Architecture', 'Platform Architecture'],
      },
    ],
  },
  {
    company: 'Blacksmith',
    meta: 'Full-time · Hybrid · Shah Alam, Malaysia',
    roles: [
      {
        title: 'Full Stack Data Engineer',
        period: 'Sep 2021 — Jul 2025 · 3 yrs 11 mos',
        points: [
          'Built a real-time streaming analytics service with Apache Kafka and Apache Flink, using the Kubernetes REST API to spin up pods per tenancy on Google Kubernetes Engine, provisioned via Terraform.',
          'Implemented Apache Camel for source/sink integration and Ververica (Apache Flink) for real-time streaming analytics.',
        ],
        tags: ['Apache Kafka', 'Apache Flink', 'Kubernetes', 'Terraform', 'GKE'],
      },
    ],
  },
  {
    company: 'Nematix',
    meta: 'Full-time · Kuala Lumpur, Malaysia',
    roles: [
      {
        title: 'Full Stack Engineer',
        period: 'Jun 2020 — Dec 2021 · 1 yr 7 mos',
        points: [
          'Developed with .NET Core on the ASP.NET Zero framework.',
          'Built a big-data pipeline for AIS NMEA data using Apache Spark & Hadoop, Google DataProc & GKE, Databricks, Delta Lake, and Superset.',
        ],
        tags: ['.NET Core', 'Apache Spark', 'Hadoop', 'Databricks', 'Delta Lake'],
      },
    ],
  },
  {
    company: 'iMoney Group',
    meta: 'Kuala Lumpur, Malaysia · 2 yrs 4 mos',
    roles: [
      {
        title: 'Senior Software Engineer',
        period: 'Jan 2020 — Aug 2020',
        points: ['Frontend development across the product suite.'],
        tags: ['Frontend'],
      },
      {
        title: 'Software Engineer',
        period: 'May 2018 — Jan 2020 · 1 yr 9 mos',
        points: [
          'Built microfrontends with Vue.js, Python Django, and Golang — split vertically per product (personal loan, credit card, home loan, insurance, broadband).',
          'Heavy use of AWS: Elastic Beanstalk, Amplify, RDS Aurora, S3, API Gateway, and Lambda.',
          'Delivered a new Bank UI for the Application Document Centre using serverless AWS SAM and AWS Amplify on Vue.',
        ],
        tags: ['Vue.js', 'Golang', 'Django', 'AWS Lambda', 'Microfrontends'],
      },
    ],
  },
  {
    company: 'JobStreet.com',
    meta: 'Kuala Lumpur, Malaysia · 6 yrs 7 mos',
    roles: [
      {
        title: 'Software Engineer',
        period: 'Nov 2011 — May 2018',
        points: [
          'Built and maintained hirer and job-seeker platforms (SiVA, Talent Search) using PHP, Laravel, ASP.NET, and AngularJS across Agile/Scrum teams.',
          'Developed REST APIs (Laravel, Swagger), full-text search with Apache Solr, and async messaging via RabbitMQ — containerised with Docker.',
          'Delivered the Re-Engagement notification platform, migrating to AWS cloud and microservices (SNS, SQS, Lambda, Node.js, Databricks) across email, browser, mobile push, and chatbot channels.',
        ],
        tags: ['PHP', 'Laravel', 'AngularJS', 'Apache Solr', 'AWS'],
      },
    ],
  },
];

const skillGroups = [
  {
    label: 'Languages & Frameworks',
    skills: ['Laravel', 'PHP', 'FilamentPHP', 'Vue.js', 'Node.js', 'Golang', 'Python', 'Django', '.NET Core', 'Flutter', 'Astro'],
  },
  {
    label: 'Cloud & DevOps',
    skills: ['Kubernetes', 'Google Kubernetes Engine', 'Docker', 'Terraform', 'AWS', 'Google Cloud', 'DevOps'],
  },
  {
    label: 'Data & Streaming',
    skills: ['Apache Kafka', 'Apache Flink', 'Apache Spark', 'Hadoop', 'Databricks', 'Delta Lake', 'Apache Camel', 'Superset'],
  },
  {
    label: 'Leadership & Strategy',
    skills: ['Agile Coaching', 'Software Architecture', 'Platform Architecture', 'Growth Hacking', 'Technical Training'],
  },
];
---

<BaseLayout
  title="Habib bin Talib — CEO"
  description="Meet Habib bin Talib, CEO of SyncTexts — full-stack engineer, cloud architect, and serial founder with 8+ years building production platforms across web, data, and Kubernetes infrastructure in Malaysia."
>
  <section class="container section profile-hero reveal">
    <div class="profile-header">
      <div class="profile-avatar">
        <img src="/images/team/habib.webp" alt="Habib bin Talib" loading="lazy" onerror="this.style.display='none'; this.parentElement.classList.add('avatar-fallback');" />
        <span class="avatar-initials">HT</span>
      </div>
      <div class="profile-intro">
        <h1 class="profile-name">Habib bin Talib</h1>
        <span class="profile-role">Chief Executive Officer, SyncTexts</span>
        <p class="profile-headline">Digital Nomad · Community Builder · Agile Coach · Family Man</p>
        <p class="profile-location">📍 Kuala Lumpur, Malaysia</p>
        <div class="profile-links">
          <a href="https://github.com/habibtalib" target="_blank" rel="noopener" class="profile-link glass-panel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/habibtalib/" target="_blank" rel="noopener" class="profile-link glass-panel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="container section reveal">
    <div class="profile-section glass-panel">
      <h2>About</h2>
      <p>Full-stack engineer, cloud architect, and serial founder based in Kuala Lumpur, Malaysia, with 8+ years building production software — from microfrontend platforms at iMoney and real-time streaming analytics on Kubernetes at Blacksmith, to founding SyncTexts, a software house delivering government and enterprise systems across the country.</p>
      <p>Today I lead SyncTexts as CEO and Battut, a Syariah-compliant social platform scaling across MENA. I founded Tarbyh, serve as a Fellow at HASAN.VC, and consult on cloud and DevOps at PINC Technology. Beyond the keyboard, I'm an active community builder and trainer — teaching Laravel, Figma, and AI tooling to public-sector teams and the wider Malaysian tech community.</p>
    </div>
  </section>

  <section class="container section reveal">
    <h2 class="profile-block-title">Experience</h2>
    <div class="timeline">
      {experience.map((company) => (
        <div class="timeline-item glass-panel reveal">
          <div class="timeline-marker"></div>
          <div class="timeline-company">{company.company}</div>
          <div class="timeline-meta">{company.meta}</div>
          {company.roles.map((role) => (
            <div class="timeline-role">
              <h3>{role.title}</h3>
              <span class="timeline-period">{role.period}</span>
              <ul>
                {role.points.map((point) => <li>{point}</li>)}
              </ul>
              <div class="profile-tags">
                {role.tags.map((tag) => <span class="profile-tag">{tag}</span>)}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <section class="container section reveal">
    <div class="profile-grid">
      <div class="profile-section glass-panel reveal">
        <h2>Skills</h2>
        <div class="skill-groups">
          {skillGroups.map((group) => (
            <div class="skill-group">
              <span class="skill-group-label">{group.label}</span>
              <div class="profile-tags">
                {group.skills.map((skill) => <span class="profile-tag">{skill}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="profile-section glass-panel reveal">
        <h2>Education</h2>
        <div class="profile-project" style="cursor: default;">
          <h3>Coventry University</h3>
          <p>BSc Computer Science · 2010</p>
        </div>
        <div class="profile-project" style="cursor: default; margin-top: 0.75rem;">
          <h3>Kolej Poly-Tech MARA</h3>
          <p>Diploma in Computer Science · 2007</p>
        </div>
        <h2 style="margin-top: 1.75rem;">Community</h2>
        <div class="profile-project" style="cursor: default;">
          <h3>Techtamu — Crew Member</h3>
          <p>Organising tech community events, networking, and knowledge sharing across the Malaysian developer scene.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container section reveal">
    <div class="profile-section glass-panel">
      <h2>Notable Open Source</h2>
      <p>On GitHub since 2014 with 1,800+ repositories spanning web frameworks, cloud tooling, payment integrations, and mobile development.</p>
      <div class="profile-projects">
        <a href="https://github.com/habibtalib/kursus-laravel-4hari" target="_blank" rel="noopener" class="profile-project">
          <h3>Kursus Laravel 4 Hari</h3>
          <p>Comprehensive Laravel course notes and labs in Bahasa Melayu</p>
          <span class="profile-tag">Blade</span>
        </a>
        <a href="https://github.com/habibtalib/laravel-securepay" target="_blank" rel="noopener" class="profile-project">
          <h3>Laravel SecurePay</h3>
          <p>Laravel package for SecurePay Malaysia payment gateway (FPX, DuitNow, Direct Debit)</p>
          <span class="profile-tag">PHP</span>
        </a>
        <a href="https://github.com/habibtalib/filament-flowstone" target="_blank" rel="noopener" class="profile-project">
          <h3>Filament Flowstone</h3>
          <p>Filament plugin for Laravel Workflow Engine with Symfony Workflow integration</p>
          <span class="profile-tag">PHP</span>
        </a>
        <a href="https://github.com/habibtalib/filament-multitenant" target="_blank" rel="noopener" class="profile-project">
          <h3>Filament Multitenant</h3>
          <p>Multi-tenancy implementation for FilamentPHP applications</p>
          <span class="profile-tag">Blade</span>
        </a>
      </div>
    </div>
  </section>

  <section class="container section reveal">
    <div class="profile-cta glass-panel">
      <h2>Work With Me</h2>
      <p>Looking for a technology partner? Let's discuss how SyncTexts can help your next project.</p>
      <a href="/contact" class="btn btn-primary btn-lg">Get In Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-header {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .profile-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--glass-border);
    background: linear-gradient(135deg, var(--primary-glow), var(--secondary-glow));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .avatar-initials {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--text-secondary);
    user-select: none;
  }

  .profile-avatar:not(.avatar-fallback) .avatar-initials {
    display: none;
  }

  .avatar-fallback img {
    display: none;
  }

  .profile-intro {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .profile-name {
    font-size: 2.5rem;
    color: var(--text-primary);
  }

  .profile-role {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .profile-headline {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .profile-location {
    color: var(--text-dimmed);
    font-size: 0.95rem;
  }

  .profile-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .profile-link:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .profile-block-title {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .profile-section {
    padding: 2rem;
  }

  .profile-section h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .profile-section p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-item {
    position: relative;
    padding: 1.75rem 2rem 1.75rem 2.5rem;
  }

  .timeline-marker {
    position: absolute;
    left: 0;
    top: 2rem;
    width: 4px;
    height: calc(100% - 3.5rem);
    border-radius: 4px;
    background: linear-gradient(180deg, var(--primary), var(--secondary));
  }

  .timeline-company {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .timeline-meta {
    font-size: 0.85rem;
    color: var(--text-dimmed);
    margin-top: 0.25rem;
  }

  .timeline-role {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--glass-border);
  }

  .timeline-role:first-of-type {
    margin-top: 1rem;
    padding-top: 0;
    border-top: none;
  }

  .timeline-role h3 {
    font-size: 1.05rem;
    color: var(--text-primary);
  }

  .timeline-period {
    display: block;
    font-size: 0.85rem;
    color: var(--primary);
    margin-top: 0.15rem;
    margin-bottom: 0.75rem;
  }

  .timeline-role ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .timeline-role li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .timeline-role li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--primary);
  }

  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .profile-tag {
    padding: 0.3rem 0.75rem;
    font-size: 0.8rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary);
    border: 1px solid rgba(99, 102, 241, 0.2);
  }

  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-group-label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-dimmed);
    margin-bottom: 0.6rem;
  }

  .profile-projects {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .profile-project {
    display: block;
    padding: 1rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--glass-border);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  a.profile-project:hover {
    border-color: var(--primary);
  }

  .profile-project h3 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .profile-project p {
    font-size: 0.85rem;
    color: var(--text-dimmed);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .profile-cta {
    text-align: center;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .profile-cta h2 {
    font-size: 2rem;
  }

  .profile-cta p {
    color: var(--text-secondary);
    max-width: 500px;
  }

  @media (max-width: 900px) {
    .profile-header {
      flex-direction: column;
      text-align: center;
    }

    .profile-links {
      justify-content: center;
    }

    .profile-grid {
      grid-template-columns: 1fr;
    }

    .profile-name {
      font-size: 2rem;
    }
  }
</style>
