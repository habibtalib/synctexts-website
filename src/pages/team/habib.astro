---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Habib bin Talib — CEO | SyncTexts" description="Meet Habib bin Talib, CEO of SyncTexts Solution — full-stack engineer, cloud architect, and digital transformation leader based in Malaysia.">
  <section class="container section profile-hero reveal">
    <div class="profile-header">
      <div class="profile-avatar">
        <img src="/images/team/habib.webp" alt="Habib bin Talib" loading="lazy" onerror="this.style.display='none'; this.parentElement.classList.add('avatar-fallback');" />
        <span class="avatar-initials">HT</span>
      </div>
      <div class="profile-intro">
        <h1 class="profile-name">Habib bin Talib</h1>
        <span class="profile-role">Chief Executive Officer</span>
        <p class="profile-location">Malaysia</p>
        <div class="profile-links">
          <a href="https://github.com/habibtalib" target="_blank" rel="noopener" class="profile-link glass-panel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/habibtalib/" target="_blank" rel="noopener" class="profile-link glass-panel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="container section reveal">
    <div class="profile-grid">
      <div class="profile-section glass-panel reveal">
        <h2>About</h2>
        <p>Visionary technologist with deep expertise in full-stack engineering, cloud infrastructure, and digital transformation. Leads SyncTexts with a hands-on approach — from architecting scalable platforms to delivering enterprise solutions.</p>
        <p>On GitHub since 2014 with 1,800+ repositories, spanning web frameworks, cloud tooling, payment integrations, and mobile development. Passionate about building tools that solve real problems.</p>
      </div>

      <div class="profile-section glass-panel reveal">
        <h2>Tech Stack</h2>
        <div class="profile-tags">
          <span class="profile-tag">Laravel</span>
          <span class="profile-tag">PHP</span>
          <span class="profile-tag">Node.js</span>
          <span class="profile-tag">Astro</span>
          <span class="profile-tag">Vue.js</span>
          <span class="profile-tag">Flutter</span>
          <span class="profile-tag">Kubernetes</span>
          <span class="profile-tag">Docker</span>
          <span class="profile-tag">Terraform</span>
          <span class="profile-tag">Python</span>
          <span class="profile-tag">FilamentPHP</span>
          <span class="profile-tag">PostgreSQL</span>
          <span class="profile-tag">Google Cloud</span>
          <span class="profile-tag">AWS</span>
        </div>
      </div>

      <div class="profile-section glass-panel reveal">
        <h2>Notable Projects</h2>
        <div class="profile-projects">
          <a href="https://github.com/habibtalib/kursus-laravel-4hari" target="_blank" rel="noopener" class="profile-project">
            <h3>Kursus Laravel 4 Hari</h3>
            <p>Comprehensive Laravel course notes and labs in Bahasa Melayu</p>
            <span class="profile-tag">Blade</span>
          </a>
          <a href="https://github.com/habibtalib/laravel-securepay" target="_blank" rel="noopener" class="profile-project">
            <h3>Laravel SecurePay</h3>
            <p>Laravel package for SecurePay Malaysia payment gateway (FPX, DuitNow, Direct Debit)</p>
            <span class="profile-tag">PHP</span>
          </a>
          <a href="https://github.com/habibtalib/filament-flowstone" target="_blank" rel="noopener" class="profile-project">
            <h3>Filament Flowstone</h3>
            <p>Filament plugin for Laravel Workflow Engine with Symfony Workflow integration</p>
            <span class="profile-tag">PHP</span>
          </a>
          <a href="https://github.com/habibtalib/filament-multitenant" target="_blank" rel="noopener" class="profile-project">
            <h3>Filament Multitenant</h3>
            <p>Multi-tenancy implementation for FilamentPHP applications</p>
            <span class="profile-tag">Blade</span>
          </a>
        </div>
      </div>

      <div class="profile-section glass-panel reveal">
        <h2>GitHub Stats</h2>
        <div class="profile-stats">
          <div class="stat-item">
            <span class="stat-number">1,800+</span>
            <span class="stat-label">Repositories</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">10+</span>
            <span class="stat-label">Years on GitHub</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">64</span>
            <span class="stat-label">Followers</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container section reveal">
    <div class="profile-cta glass-panel">
      <h2>Work With Me</h2>
      <p>Looking for a technology partner? Let's discuss how SyncTexts can help your next project.</p>
      <a href="/contact" class="btn btn-primary btn-lg">Get In Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-header {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .profile-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--glass-border);
    background: linear-gradient(135deg, var(--primary-glow), var(--secondary-glow));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .avatar-initials {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--text-secondary);
    user-select: none;
  }

  .profile-avatar:not(.avatar-fallback) .avatar-initials {
    display: none;
  }

  .avatar-fallback img {
    display: none;
  }

  .profile-intro {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .profile-name {
    font-size: 2.5rem;
    color: var(--text-primary);
  }

  .profile-role {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .profile-location {
    color: var(--text-dimmed);
    font-size: 0.95rem;
  }

  .profile-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .profile-link:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .profile-section {
    padding: 2rem;
  }

  .profile-section h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .profile-section p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .profile-tag {
    padding: 0.3rem 0.75rem;
    font-size: 0.8rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary);
    border: 1px solid rgba(99, 102, 241, 0.2);
  }

  .profile-projects {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .profile-project {
    padding: 1rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--glass-border);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .profile-project:hover {
    border-color: var(--primary);
  }

  .profile-project h3 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .profile-project p {
    font-size: 0.85rem;
    color: var(--text-dimmed);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .profile-stats {
    display: flex;
    gap: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-dimmed);
  }

  .profile-cta {
    text-align: center;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .profile-cta h2 {
    font-size: 2rem;
  }

  .profile-cta p {
    color: var(--text-secondary);
    max-width: 500px;
  }

  @media (max-width: 900px) {
    .profile-header {
      flex-direction: column;
      text-align: center;
    }

    .profile-links {
      justify-content: center;
    }

    .profile-grid {
      grid-template-columns: 1fr;
    }

    .profile-name {
      font-size: 2rem;
    }

    .profile-stats {
      justify-content: center;
    }
  }
</style>
