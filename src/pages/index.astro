---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import TechGrid from '../components/TechGrid.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const projects = allProjects.slice(0, 3);

const testimonials = await getCollection('testimonials');
---

<BaseLayout title="Web Development, DevOps & Analytics Agency" description="SyncTexts delivers premium web development, DevOps automation, and data analytics solutions. Transform your digital presence with our expert team.">
  <Hero />

  <ServicesGrid />

  <TechGrid />

  <!-- Portfolio Preview -->
  <section id="projects" class="projects container section">
    <div class="section-heading reveal">
      <h2>Featured <span class="text-gradient">Projects</span></h2>
      <p>A selection of recent work, demonstrating our capabilities across the full stack.</p>
    </div>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <ProjectCard
          tag={p.data.languages.join(' / ')}
          title={p.data.title}
          description={p.data.description}
          delay={`${(i + 1) * 0.1}s`}
          href={`/portfolio/${p.data.caseStudySlug || p.id}`}
        />
      ))}
    </div>

    <div class="section-view-all reveal">
      <a href="/portfolio" class="view-all-link">View All Projects &rarr;</a>
    </div>
  </section>

  <!-- Testimonials Preview -->
  <section id="testimonials" class="testimonials container section">
    <div class="section-heading reveal">
      <h2>What <span class="text-gradient">Clients Say</span></h2>
      <p>Trusted by teams building the next generation of digital products.</p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <TestimonialCard
          quote={t.data.quote}
          name={t.data.name}
          role={t.data.role}
          company={t.data.company}
          delay={`${(i + 1) * 0.1}s`}
        />
      ))}
    </div>

    <div class="section-view-all reveal">
      <a href="/portfolio" class="view-all-link">Read More Testimonials &rarr;</a>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
