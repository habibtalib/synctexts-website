---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Premium Web & DevOps Agency">
  <section class="hero container reveal">
    <div class="hero-content">
      <div class="badge">Future-Proof Engineering</div>
      <h1 class="hero-title">
        We Build <span class="text-gradient">Digital Products</span> That Scale.
      </h1>
      <p class="hero-subtitle">
        From brilliant web applications and mobile experiences to rock-solid Kubernetes infrastructure, SyncTexts is
        your premier technology partner.
      </p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-primary btn-lg">Partner With Us</a>
        <a href="/portfolio" class="btn btn-secondary btn-lg">Explore Expertise</a>
      </div>
    </div>
  </section>
</BaseLayout>
