---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('gallery')).sort((a, b) => {
  // newest first, falling back to explicit order
  const ad = a.data.date ? a.data.date.getTime() : 0;
  const bd = b.data.date ? b.data.date.getTime() : 0;
  if (ad !== bd) return bd - ad;
  return a.data.order - b.data.order;
});

const fmt = (d?: Date) =>
  d ? d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '';
---

<BaseLayout title="Gallery" description="Photos from SyncTexts events, training sessions, and community activities.">
  <PageHeader title="Gallery" subtitle="Events, training & community moments" />

  <section class="container section">
    {items.length === 0 ? (
      <div class="gallery-empty glass-panel reveal">
        <p>Our media library is being curated — photos from events, training, and community activities will appear here soon.</p>
      </div>
    ) : (
      <div class="gallery-grid">
        {items.map((item, i) => (
          <button
            class="gallery-card glass-panel reveal"
            style={`--delay: ${(i % 6 + 1) * 0.08}s`}
            data-full={item.data.image}
            data-title={item.data.title}
            data-desc={item.data.description}
            data-date={fmt(item.data.date)}
            aria-label={`View ${item.data.title}`}
          >
            <div class="gallery-thumb">
              <img src={item.data.image} alt={item.data.title} loading="lazy" />
            </div>
            <div class="gallery-meta">
              {item.data.date && <span class="gallery-date">{fmt(item.data.date)}</span>}
              <h3>{item.data.title}</h3>
              <p>{item.data.description}</p>
            </div>
          </button>
        ))}
      </div>
    )}
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <figure class="lightbox-figure">
      <img id="lightbox-img" src="" alt="" />
      <figcaption>
        <span class="lightbox-date" id="lightbox-date"></span>
        <h3 id="lightbox-title"></h3>
        <p id="lightbox-desc"></p>
      </figcaption>
    </figure>
  </div>
</BaseLayout>

<script>
  function initGalleryLightbox() {
    const lightbox = document.getElementById('lightbox');
    if (!lightbox) return;
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const titleEl = document.getElementById('lightbox-title');
    const descEl = document.getElementById('lightbox-desc');
    const dateEl = document.getElementById('lightbox-date');

    function open(card: HTMLElement) {
      if (!img || !titleEl || !descEl || !dateEl) return;
      img.src = card.dataset.full || '';
      img.alt = card.dataset.title || '';
      titleEl.textContent = card.dataset.title || '';
      descEl.textContent = card.dataset.desc || '';
      dateEl.textContent = card.dataset.date || '';
      lightbox!.classList.add('open');
      lightbox!.setAttribute('aria-hidden', 'false');
      document.body.classList.add('lightbox-open');
    }
    function close() {
      lightbox!.classList.remove('open');
      lightbox!.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('lightbox-open');
    }

    document.querySelectorAll<HTMLElement>('.gallery-card').forEach((card) => {
      card.addEventListener('click', () => open(card));
    });
    lightbox.querySelector('.lightbox-close')?.addEventListener('click', close);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('open')) close();
    });
  }

  document.addEventListener('astro:page-load', initGalleryLightbox);
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .gallery-card {
    padding: 0;
    overflow: hidden;
    text-align: left;
    cursor: pointer;
    border: 1px solid var(--glass-border);
    background: var(--bg-surface);
    color: inherit;
    font: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .gallery-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
  }

  .gallery-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-base);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-card:hover .gallery-thumb img {
    transform: scale(1.05);
  }

  .gallery-meta {
    padding: 1.25rem 1.4rem 1.5rem;
  }

  .gallery-date {
    font-size: 0.75rem;
    color: var(--primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .gallery-meta h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin: 0.35rem 0 0.5rem;
  }

  .gallery-meta p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .gallery-empty {
    padding: 3rem 2rem;
    text-align: center;
  }

  .gallery-empty p {
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 4vh 4vw;
    background: rgba(6, 6, 8, 0.88);
    backdrop-filter: blur(8px);
  }

  .lightbox.open {
    display: flex;
  }

  :global(body.lightbox-open) {
    overflow: hidden;
  }

  .lightbox-figure {
    max-width: 1000px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
  }

  .lightbox-figure img {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
    border-radius: 10px;
    border: 1px solid var(--glass-border);
  }

  .lightbox-figure figcaption {
    text-align: center;
    color: var(--text-secondary);
  }

  .lightbox-date {
    font-size: 0.75rem;
    color: var(--primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lightbox-figure h3 {
    color: var(--text-primary);
    font-size: 1.3rem;
    margin: 0.25rem 0 0.4rem;
  }

  .lightbox-figure p {
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.75rem;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .lightbox-close:hover {
    color: var(--text-primary);
  }
</style>
