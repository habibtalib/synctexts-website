---
interface Props {
  tag: string;
  title: string;
  description: string;
  delay?: string;
  href?: string;
}

const { tag, title, description, delay, href = '/portfolio' } = Astro.props;
---

<div class="project-card glass-panel reveal" style={delay ? `--delay: ${delay}` : ''}>
  <div class="project-content">
    <span class="project-tag">{tag}</span>
    <h3>{title}</h3>
    <p>{description}</p>
    <a href={href} class="project-link">View Details &rarr;</a>
  </div>
</div>
