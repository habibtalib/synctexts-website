---
interface Props {
  title: string;
  description: string;
  languages: string[];
  updatedAt: string | null;
  caseStudySlug: string | null;
  cover?: string | null;
  delay?: string;
}

const { title, description, languages, updatedAt, caseStudySlug, cover, delay } = Astro.props;
const cardHref = caseStudySlug ? `/portfolio/${caseStudySlug}` : null;

// Truncate description to ~120 chars
const truncated = description.length > 120 ? description.slice(0, 117) + '...' : description;

// Format date as "Updated Mar 2026"
let formattedDate: string | null = null;
if (updatedAt) {
  const d = new Date(updatedAt);
  const month = d.toLocaleString('en-US', { month: 'short' });
  const year = d.getFullYear();
  formattedDate = `Updated ${month} ${year}`;
}
---

<div class="portfolio-card glass-panel reveal" style={delay ? `--delay: ${delay}` : ''}>
  {cover && (
    cardHref ? (
      <a href={cardHref} class="portfolio-cover" aria-label={title}>
        <img src={cover} alt={`${title} screenshot`} loading="lazy" />
      </a>
    ) : (
      <div class="portfolio-cover">
        <img src={cover} alt={`${title} screenshot`} loading="lazy" />
      </div>
    )
  )}
  <div class="portfolio-card-content">
    <h3>{title}</h3>
    <p class="portfolio-description">{truncated}</p>
    <div class="portfolio-languages">
      {languages.map((lang) => (
        <span class="tech-tag">{lang}</span>
      ))}
    </div>
    <div class="portfolio-card-footer">
      {formattedDate && <span class="updated-date">{formattedDate}</span>}
      {caseStudySlug ? (
        <a href={`/portfolio/${caseStudySlug}`} class="project-link">View Case Study &rarr;</a>
      ) : (
        <span class="project-link muted">View Details</span>
      )}
    </div>
  </div>
</div>

<style>
  .portfolio-card {
    overflow: hidden;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .portfolio-cover {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--glass-border);
    background: var(--bg-base);
  }

  .portfolio-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.4s ease;
  }

  .portfolio-cover:hover img {
    transform: scale(1.04);
  }

  .portfolio-card :global(.portfolio-card-content) {
    padding: 1.75rem 1.75rem 1.5rem;
  }
</style>
