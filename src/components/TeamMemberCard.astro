---
interface Props {
  name: string;
  role: string;
  bio: string;
  photo: string;
  slug?: string;
  delay?: string;
}

const { name, role, bio, photo, slug, delay } = Astro.props;
---

<div class="team-card glass-panel reveal" style={delay ? `--delay: ${delay}` : ''}>
  <div class="team-avatar">
    <img src={photo} alt={name} loading="lazy" onerror="this.style.display='none'; this.parentElement.classList.add('avatar-fallback');" />
    <span class="avatar-initials">{name.split(' ').map(n => n[0]).join('')}</span>
  </div>
  <div class="team-info">
    <h3 class="team-name">{slug ? <a href={`/team/${slug}`} class="team-name-link">{name}</a> : name}</h3>
    <span class="team-role">{role}</span>
    <p class="team-bio">{bio}</p>
  </div>
</div>

<style>
  .team-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .team-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--glass-border);
    background: linear-gradient(135deg, var(--primary-glow), var(--secondary-glow));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }

  .team-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .avatar-initials {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-secondary);
    user-select: none;
  }

  .team-avatar:not(.avatar-fallback) .avatar-initials {
    display: none;
  }

  .avatar-fallback img {
    display: none;
  }

  .team-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .team-name {
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  .team-role {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .team-bio {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: 0.5rem;
  }

  .team-name-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .team-name-link:hover {
    color: var(--primary);
  }
</style>
